# ── Daily.co (video rooms) ──────────────────────────────────────────────
# Required. Without it, creating/joining video rooms fails.
DAILY_API_KEY=

# ── Turso / libSQL (persistent storage) ─────────────────────────────────
# Required in production (e.g. Vercel). Create a DB with the Turso CLI:
#   turso db create friends-family
#   turso db show friends-family --url        # -> TURSO_DATABASE_URL
#   turso db tokens create friends-family     # -> TURSO_AUTH_TOKEN
# If both are unset, the app falls back to a local SQLite file (file:.data/local.db)
# for development only — that fallback does NOT work on Vercel.
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=
